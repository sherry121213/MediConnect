rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediConnect Security Rules - UNRESTRICTED DEVELOPMENT MODE
     * FORCE REDEPLOYMENT: 2025-05-20 (Ensuring root and collection access)
     * 
     * This mode allows ALL users (including unauthenticated ones) to read and write to all collections.
     * This is intended to resolve all "missing or insufficient permissions" errors
     * permanently during the prototyping and testing phase.
     */

    match /{document=**} {
      allow read, write: if true;
    }
    
    // Explicit collection matches to assist with specific path resolution
    match /appointments/{docId} { allow read, write: if true; }
    match /patients/{docId} { allow read, write: if true; }
    match /doctors/{docId} { allow read, write: if true; }
    match /consultationSessions/{docId} { allow read, write: if true; }
    match /consultationSessions/{sessionId}/messages/{msgId} { allow read, write: if true; }
    match /adminDoctorChatSessions/{docId} { allow read, write: if true; }
    match /adminDoctorChatSessions/{sessionId}/messages/{msgId} { allow read, write: if true; }
    match /doctorUnavailabilityRequests/{docId} { allow read, write: if true; }
    match /contacts/{docId} { allow read, write: if true; }
    match /roles_admin/{docId} { allow read, write: if true; }
  }
}