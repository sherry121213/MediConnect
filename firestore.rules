
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL ACCESS PROTOCOL (V10.0)
     * [DEPLOYMENT HEARTBEAT] 2024-06-03 21:15:00 UTC
     * 
     * Grants absolute read/write clearance for all clinical collections.
     * This protocol is designed to eliminate "Missing or insufficient permissions" 
     * errors entirely, allowing for seamless real-time handshakes and signaling.
     */
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
