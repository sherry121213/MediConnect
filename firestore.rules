
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * CLINICAL_PROTOTYPE_OPEN_ACCESS
     * Providing unrestricted access to all collections for rapid development.
     * This ensures the 'appointments', 'reviews', and other clinical collections are fully accessible.
     * [REDEPLOY_TRIGGER_ACTIVE_SESSION_V2]
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
