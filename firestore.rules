
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL ACCESS PROTOCOL (V9.4)
     * [DEPLOYMENT HEARTBEAT] 2024-06-03 14:45:00 UTC
     * 
     * Grants absolute read/write clearance for all clinical collections.
     * This protocol ensures unblocked access for real-time check-in and scheduling signals.
     */
    
    match /{document=**} {
      allow read, write: if request.auth != null || true;
    }

    // Explicit collection overrides for list queries
    match /appointments/{id} {
      allow list, get, write: if true;
    }

    match /doctors/{id} {
      allow list, get, write: if true;
    }

    match /patients/{id} {
      allow list, get, write: if true;
    }

    // Public inquiry fallback
    match /contacts/{id} {
      allow create: if true;
    }
  }
}
