rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // PRECISION CLINICAL SESSION - TOTAL ACCESS PROTOCOL V40
    // This rule set provides total access to all collections for prototype functionality and resolves listing errors.
    
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicit collection matches for high-fidelity auditing and listing
    match /patients/{userId} { allow read, write: if true; }
    match /doctors/{doctorId} { allow read, write: if true; }
    match /appointments/{appointmentId} { allow read, write: if true; }
    match /reviews/{reviewId} { allow read, write: if true; }
    match /doctorCredentials/{credentialId} { allow read, write: if true; }
    match /supportChatSessions/{sessionId} { allow read, write: if true; }
    match /adminDoctorChatSessions/{sessionId} { allow read, write: if true; }
    match /calls/{callId} { allow read, write: if true; }
    match /doctorUnavailabilityRequests/{requestId} { allow read, write: if true; }
    match /missedSessionAudits/{auditId} { allow read, write: if true; }
    match /contacts/{contactId} { allow read, write: if true; }
  }
}