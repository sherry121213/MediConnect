rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // PRECISION CLINICAL SESSION - STABLE OPEN ACCESS V26
    // This rule set provides total access for prototype functionality.
    
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicit collection matches for high-fidelity auditing (redundant but safer for cold-starts)
    match /patients/{userId} { allow read, write: if true; }
    match /doctors/{doctorId} { allow read, write: if true; }
    match /appointments/{appointmentId} { allow read, write: if true; }
    match /reviews/{reviewId} { allow read, write: if true; }
    match /doctorCredentials/{credentialId} { allow read, write: if true; }
    match /supportChatSessions/{sessionId} { allow read, write: if true; }
    match /adminDoctorChatSessions/{sessionId} { allow read, write: if true; }
    match /calls/{callId} { allow read, write: if true; }
  }
}