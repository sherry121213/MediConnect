rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediConnect Global Access Policy - PROTOTYPE UNLOCK
     * DEPLOYMENT_SIG: REFRESH_PERMISSIONS_2025_05_21_T14_30
     * 
     * This policy allows unrestricted access to all collections to resolve 
     * persistent "missing or insufficient permissions" errors during the 
     * rapid prototyping and testing phase.
     */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}