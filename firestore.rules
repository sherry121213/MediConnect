
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * CLINICAL_PROTOTYPE_STABILIZATION
     * Open access for prototype development and clinical workflow verification.
     * Covers: Patients, Doctors, Appointments, Reviews, and Support Channels.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
