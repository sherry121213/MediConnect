rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Admins can read and write all documents.
    match /{document=**} {
      allow read, write: if get(/databases/$(database)/documents/patients/$(request.auth.uid)).data.role == 'admin';
    }

    // Patients collection: users can only access their own document.
    match /patients/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
    }

    // Doctors collection: all users can read. Doctors can create and update their own profile.
    match /doctors/{doctorId} {
      allow read: if true;
      allow create, update: if request.auth.uid == doctorId;
      // Admin write access (create/delete) is handled by the global admin rule.
    }
    
    // Appointments collection: only participants (patient/doctor) can access.
    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.patientId;
      allow update: if isSignedIn() && (request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId);
    }
    
    // Contact form: anyone can create (write), but only admins can read.
    match /contacts/{contactId} {
      allow create: if true;
      // Read access is handled by the admin rule above.
    }
  }
}
