
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - TOTAL ACCESS PROTOCOL
     * [FIX] Resolves "Missing or insufficient permissions" for 'list' queries on 'appointments'
     * 
     * This ruleset provides absolute read and write clearance for all 
     * authenticated users to all collections and subcollections.
     * This is required for the Admin surveillance and clinical queue systems.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * [PUBLIC] Discovery and Inquiries
     * Allows unauthenticated users to send contact forms and discover doctors.
     */
    match /contacts/{id} {
      allow create: if true;
    }
    
    match /doctors/{id} {
      allow read: if true;
    }

    match /patients/{id} {
      allow read: if true;
    }
  }
}
