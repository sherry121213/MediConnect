
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL ACCESS PROTOCOL (V5.0)
     * [DEPLOYMENT HEARTBEAT] 2024-06-01 14:30:00 UTC
     * 
     * Grants absolute read/write clearance to ensure all clinical workflows,
     * queue monitoring, and booking systems are completely unblocked.
     */
    
    match /{document=**} {
      allow read, write: if true;
    }

    // Public inquiry fallback
    match /contacts/{id} {
      allow create: if true;
    }
  }
}
