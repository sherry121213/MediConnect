
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL CLINICAL ACCESS PROTOCOL (V4.1)
     * [DEPLOYMENT HEARTBEAT] 2024-05-27 12:45:00 UTC
     * 
     * Grants absolute read/write clearance for authenticated clinical workflows.
     * This includes gated state changes (check-in, start, join).
     */
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Public inquiry access
    match /contacts/{id} {
      allow create: if true;
    }
  }
}
