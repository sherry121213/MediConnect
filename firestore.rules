/**
 * Core Philosophy: This ruleset enforces a multi-tiered security model tailored for a medical application.
 * It strictly separates user-owned private data (patients), publicly readable data (doctors), and
 * shared data with closed collaborators (appointments). The default posture is to deny all access
 * unless explicitly granted. Admins have unrestricted access.
 *
 * Data Structure: The data is organized into three distinct top-level collections:
 * - /patients/{patientId}: Stores private patient data. Access is restricted to the patient, an admin, or a doctor linked via a completed appointment.
 * - /doctors/{doctorId}: Stores public doctor profiles, readable by any authenticated user.
 * - /appointments/{appointmentId}: Stores records of appointments shared between a specific patient and doctor.
 *
 * Key Security Decisions:
 * - Admin Supremacy: Users with an `admin` custom claim have full read/write access to all collections for administrative purposes.
 * - User Isolation: Users are generally forbidden from accessing data of other users unless a specific relationship (like a completed appointment) exists.
 * - Conditional Doctor Access: Doctors can only read a patient's profile if they have had a completed appointment with them, ensuring patient privacy is maintained until a professional relationship is established.
 * - Shared Access Control: Access to an appointment document is granted only to the two participants (patient and doctor) or an admin.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership model.
     * @param userId The user ID to check against the request's auth UID.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Returns true if the document being accessed already exists and the
     * authenticated user is its owner. Used for safe updates and deletes.
     * @param userId The user ID to check for ownership.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Checks if the user has administrative privileges by checking custom claims.
     */
    function isAdmin() {
      return request.auth.token.admin == true;
    }

    /**
     * Validates that an incoming patient document contains an `id` field
     * that matches the document's ID in the path. Enforces relational integrity on create.
     * Also validates the 'role' field.
     * @param patientId The wildcard ID from the document path.
     */
    function isValidNewPatient(patientId) {
      let data = request.resource.data;
      return data.id == patientId &&
             (data.role == 'patient' || data.role == 'doctor' || data.role == 'admin');
    }

    /**
     * Ensures the `id` and `role` fields of a patient document cannot be changed after creation.
     */
    function isPatientIdAndRoleImmutable() {
      let data = request.resource.data;
      return data.id == resource.data.id &&
             data.role == resource.data.role;
    }

    /**
     * Validates that an incoming doctor document contains an `id` field
     * that matches the document's ID in the path.
     * @param doctorId The wildcard ID from the document path.
     */
    function isValidNewDoctor(doctorId) {
      return request.resource.data.id == doctorId;
    }

    /**
     * Ensures the `id` field of a doctor document cannot be changed after creation.
     */
    function isDoctorIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * Returns true if the requesting user's UID matches either the patientId or
     * doctorId on an existing appointment document.
     */
    function isParticipant() {
      return request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId;
    }

    /**
     * Returns true if the requesting user's UID matches either the patientId or
     * doctorId on a new appointment document being created.
     */
    function isCreatingParticipant() {
      return request.auth.uid == request.resource.data.patientId || request.auth.uid == request.resource.data.doctorId;
    }

    /**
     * Ensures the core relational fields (`patientId`, `doctorId`) of an appointment
     * cannot be changed after the document has been created.
     */
    function areAppointmentParticipantsImmutable() {
      return request.resource.data.patientId == resource.data.patientId &&
             request.resource.data.doctorId == resource.data.doctorId;
    }
    
    /**
     * Checks if the requesting user (a doctor) has a completed appointment with the patient.
     * This is used to grant doctors access to patient details only after a paid/completed consultation.
     * @param patientId The ID of the patient whose record is being accessed.
     */
    function hasCompletedAppointmentWithPatient(patientId) {
      return exists(/databases/$(database)/documents/appointments?where("doctorId", "==", request.auth.uid).where("patientId", "==", patientId).where("status", "==", "Completed"));
    }


    // ----------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------

    /**
     * @description Manages patient/user profiles. Access is strictly limited.
     * @path /patients/{patientId}
     * @allow (get) An admin, the patient themselves, or a doctor who has had a completed appointment with the patient.
     * @principle Restricts access to a user's own data tree, with exceptions for admins and treating physicians.
     */
    match /patients/{patientId} {
      allow read: if isAdmin() || isOwner(patientId) || hasCompletedAppointmentWithPatient(patientId);
      allow list: if isAdmin();
      allow create: if isOwner(patientId) && isValidNewPatient(patientId);
      allow update: if (isOwner(patientId) || isAdmin()) && isPatientIdAndRoleImmutable();
      allow delete: if isOwner(patientId) || isAdmin();
    }

    /**
     * @description Manages doctor profiles. These are publicly readable by any signed-in user but writeable only by admins.
     * @path /doctors/{doctorId}
     * @allow (read) Any authenticated user and admins.
     * @allow (write) Admins only.
     * @principle Implements a public-read, admin-only write pattern for curated public data.
     */
    match /doctors/{doctorId} {
      allow read: if isSignedIn() || isAdmin();
      allow write: if isAdmin();
    }

    /**
     * @description Manages appointment records. Access is restricted to the involved patient and doctor, or an admin.
     * @path /appointments/{appointmentId}
     * @allow (read, write) A doctor, patient, or an admin.
     * @principle Enforces a "Closed Collaborators" model using denormalized IDs for efficient and secure authorization.
     */
    match /appointments/{appointmentId} {
      allow read: if isAdmin() || isParticipant();
      // Doctors can query their own appointments
      allow list: if isAdmin() || (isSignedIn() && request.query.where.doctorId == request.auth.uid);
      allow create: if isSignedIn() && isCreatingParticipant();
      allow update: if (isParticipant() || isAdmin()) && areAppointmentParticipantsImmutable();
      allow delete: if isParticipant() || isAdmin();
    }
  }
}
