
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL ACCESS PROTOCOL (PROTOTYPE MODE)
     * [TIMESTAMP] 2024-05-24 18:30:00 UTC
     * 
     * This ruleset provides absolute read and write clearance to all authenticated 
     * and unauthenticated users to resolve persistent "Missing or insufficient 
     * permissions" errors during platform surveillance and clinical operations.
     */
    
    match /{document=**} {
      allow read, write: if true;
    }

    /**
     * [EXPLICIT LISTING] 
     * These match blocks ensure that collection-level "list" queries 
     * (e.g., /appointments or /doctors) are explicitly cleared by the 
     * Firestore evaluator.
     */
    
    match /appointments/{id} {
      allow read, write: if true;
    }

    match /doctors/{id} {
      allow read, write: if true;
    }

    match /patients/{id} {
      allow read, write: if true;
    }

    match /contacts/{id} {
      allow read, write: if true;
    }

    match /reviews/{id} {
      allow read, write: if true;
    }

    match /doctorCredentials/{id} {
      allow read, write: if true;
    }

    match /supportChatSessions/{id} {
      allow read, write: if true;
    }

    match /adminDoctorChatSessions/{id} {
      allow read, write: if true;
    }

    match /missedSessionAudits/{id} {
      allow read, write: if true;
    }

    match /calls/{id} {
      allow read, write: if true;
    }
  }
}
