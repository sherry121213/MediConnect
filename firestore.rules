
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL CLINICAL ACCESS PROTOCOL (PROTOTYPE MODE)
     * [DEPLOYMENT HEARTBEAT] 2024-05-25 15:45:00 UTC
     * 
     * This ruleset grants absolute read and write clearance to all authenticated 
     * users to ensure that Admin surveillance and Provider portal logic 
     * are completely unblocked from permission errors.
     */
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * [PUBLIC ACCESS] 
     * Allow unauthenticated visitors to submit contact forms.
     */
    match /contacts/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    /**
     * [EXPLICIT LISTING FOR WATCHER SYNC]
     * These blocks ensure collection-level "list" queries are prioritized.
     */
    match /appointments/{id} { allow read, write: if request.auth != null; }
    match /doctors/{id} { allow read, write: if request.auth != null; }
    match /patients/{id} { allow read, write: if request.auth != null; }
    match /reviews/{id} { allow read, write: if request.auth != null; }
    match /doctorCredentials/{id} { allow read, write: if request.auth != null; }
    match /supportChatSessions/{id} { allow read, write: if request.auth != null; }
    match /adminDoctorChatSessions/{id} { allow read, write: if request.auth != null; }
    match /calls/{id} { allow read, write: if request.auth != null; }
    match /missedSessionAudits/{id} { allow read, write: if request.auth != null; }
  }
}
