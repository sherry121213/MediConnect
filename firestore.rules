rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * PRECISION_CLINICAL_ACCESS_V6
     * Explicitly granting full access to all collections for the prototype.
     * This ensures the 'appointments', 'reviews', 'doctorCredentials', and 'patients' 
     * collections are fully accessible to all authenticated users during development.
     * [REDEPLOY_TRIGGER_V6_FULL_ACCESS]
     */
    
    match /{document=**} {
      allow read, write: if true;
    }

    match /patients/{userId} {
      allow read, write: if true;
    }
    
    match /doctors/{doctorId} {
      allow read, write: if true;
    }
    
    match /appointments/{appointmentId} {
      allow read, write: if true;
    }
    
    match /reviews/{reviewId} {
      allow read, write: if true;
    }
    
    match /doctorCredentials/{credentialId} {
      allow read, write: if true;
    }
  }
}