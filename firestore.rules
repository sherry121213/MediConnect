
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL CLINICAL ACCESS PROTOCOL (V2.5)
     * [DEPLOYMENT HEARTBEAT] 2024-05-26 10:15:00 UTC
     * 
     * Implement total read/write protocol for authenticated clinical workflows.
     * Specific match blocks ensure collection listing is prioritized.
     */
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    match /appointments/{id} { allow read, write: if request.auth != null; }
    match /doctors/{id} { allow read, write: if request.auth != null; }
    match /patients/{id} { allow read, write: if request.auth != null; }
    match /contacts/{id} { allow create: if true; allow read, write: if request.auth != null; }
    match /reviews/{id} { allow read, write: if request.auth != null; }
    match /doctorCredentials/{id} { allow read, write: if request.auth != null; }
    match /supportChatSessions/{id} { allow read, write: if request.auth != null; }
    match /adminDoctorChatSessions/{id} { allow read, write: if request.auth != null; }
    match /calls/{id} { allow read, write: if request.auth != null; }
    match /missedSessionAudits/{id} { allow read, write: if request.auth != null; }
    match /doctorUnavailabilityRequests/{id} { allow read, write: if request.auth != null; }
  }
}
