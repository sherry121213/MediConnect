
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - PROTOCOL V61
     * 
     * [CRITICAL] REDEPLOYMENT TRIGGER: V61 - Full Global Access Protocol.
     * This ruleset provides absolute read/write clearance for all clinical 
     * segments to resolve permission blocks during rapid prototyping.
     */
    
    // Global recursive wildcard: Matches all collections and documents at any depth.
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicit root collection matches to ensure list/query compatibility
    match /patients/{docId} { allow read, write: if true; }
    match /doctors/{docId} { allow read, write: if true; }
    match /appointments/{docId} { allow read, write: if true; }
    match /reviews/{docId} { allow read, write: if true; }
    match /doctorCredentials/{docId} { allow read, write: if true; }
    match /supportChatSessions/{docId} { allow read, write: if true; }
    match /adminDoctorChatSessions/{docId} { allow read, write: if true; }
    match /consultationSessions/{docId} { allow read, write: if true; }
    match /calls/{docId} { allow read, write: if true; }
    match /doctorUnavailabilityRequests/{docId} { allow read, write: if true; }
    match /missedSessionAudits/{docId} { allow read, write: if true; }
    match /contacts/{docId} { allow read, write: if true; }
  }
}
