rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL ACCESS PROTOCOL (V18.4)
     * [DEPLOYMENT HEARTBEAT] 2025-02-14 11:45:00 UTC
     * 
     * Full clearance for all clinical collections.
     * Required to eliminate handshake latency and ensure zero permission 
     * bottlenecks during WebRTC signaling and precision session syncing.
     */
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}