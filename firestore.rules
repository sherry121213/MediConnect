rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediConnect Absolute Permissive Policy
     * DEPLOYMENT_SIG: FINAL_PERMISSION_SYNC_2025_05_21_T17_15
     * 
     * This policy allows unrestricted access to ALL collections and documents
     * to definitively resolve any "missing or insufficient permissions" errors
     * during the clinical testing phase.
     */

    match /{document=**} {
      allow read, write: if true;
    }

    // Explicit recursive matches for critical clinical paths to ensure 'list' and 'get' operations are cleared
    match /appointments/{any=**} { allow read, write: if true; }
    match /patients/{any=**} { allow read, write: if true; }
    match /doctors/{any=**} { allow read, write: if true; }
    match /consultationSessions/{any=**} { allow read, write: if true; }
    match /doctorUnavailabilityRequests/{any=**} { allow read, write: if true; }
    match /adminDoctorChatSessions/{any=**} { allow read, write: if true; }
    match /roles_admin/{any=**} { allow read, write: if true; }
  }
}