
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL ACCESS PROTOCOL
     * [TIMESTAMP] 2024-05-24 14:30:00 UTC
     * 
     * This ruleset grants absolute read and write clearance to all authenticated 
     * and unauthenticated users for this prototype environment. This is specifically 
     * implemented to resolve "Missing or insufficient permissions" errors for 
     * collection list queries (e.g., /appointments).
     */
    
    match /{document=**} {
      allow read, write: if true;
    }

    /**
     * [EXPLICIT OVERRIDE] Appointments
     * Ensures root collection queries are specifically allowed.
     */
    match /appointments/{id} {
      allow read, write: if true;
    }

    /**
     * [EXPLICIT OVERRIDE] Clinical Entities
     */
    match /doctors/{id} {
      allow read, write: if true;
    }

    match /patients/{id} {
      allow read, write: if true;
    }
    
    match /contacts/{id} {
      allow read, write: if true;
    }
  }
}
