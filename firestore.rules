
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/patients/$(request.auth.uid)).data.role == 'admin';
    }

    function isDoctorActive(doctorId) {
      let doctorDoc = get(/databases/$(database)/documents/doctors/$(doctorId));
      return !doctorDoc.exists() || doctorDoc.data.isActive != false;
    }

    // Admins can read and write all documents.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Patients collection
    match /patients/{patientId} {
      allow create: if request.auth.uid == patientId;
      allow update: if request.auth.uid == patientId;
      allow get: if request.auth.uid == patientId || get(/databases/$(database)/documents/patients/$(request.auth.uid)).data.role == 'doctor';
    }

    // Doctors collection: all users can read. Doctors can create and update their own profile only if active.
    match /doctors/{doctorId} {
      allow read: if true;
      allow create: if request.auth.uid == doctorId;
      allow update: if request.auth.uid == doctorId && isDoctorActive(doctorId);
    }
    
    // Appointments collection: only participants (patient/doctor) can access.
    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.patientId;
      allow update: if isSignedIn() && (request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId) && isDoctorActive(resource.data.doctorId);
    }
    
    // Contact form: anyone can create (write), but only admins can read.
    match /contacts/{contactId} {
      allow create: if true;
    }
  }
}
