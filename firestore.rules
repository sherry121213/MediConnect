
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Get user role safely without recursion
    function getUserRole() {
      let path = /databases/$(database)/documents/patients/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'none';
    }

    // Helper: Check if doctor is active
    function isDoctorActive(doctorId) {
      let path = /databases/$(database)/documents/doctors/$(doctorId);
      return !exists(path) || get(path).data.isActive != false;
    }

    // Patients collection
    match /patients/{userId} {
      // CRITICAL: Always allow users to read/write their own record first.
      // This check is performed locally without a 'get()' call, preventing recursion.
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Allow Doctors and Admins to read OTHER patient profiles (e.g., during consultation)
      allow read: if isSignedIn() && (getUserRole() == 'doctor' || getUserRole() == 'admin');
    }

    // Doctors collection
    match /doctors/{doctorId} {
      // Everyone can read verified doctor profiles
      allow read: if true;
      // Doctors can manage their own professional details, or admin can manage them
      allow create: if isSignedIn() && request.auth.uid == doctorId;
      allow update: if isSignedIn() && (request.auth.uid == doctorId || getUserRole() == 'admin') && isDoctorActive(doctorId);
    }
    
    // Appointments collection
    match /appointments/{appointmentId} {
      // Involved parties and admins can get specific documents
      allow get: if isSignedIn() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.doctorId ||
        getUserRole() == 'admin'
      );

      // Explicitly allow list operations if the query is filtered by the user's ID
      // This allows the Firestore engine to verify queries like .where('doctorId', '==', uid)
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.doctorId ||
        getUserRole() == 'admin'
      );

      // Patients can create appointments
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.patientId;
      
      // Involved parties can update (add diagnosis/status) if the doctor is active
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.doctorId ||
        getUserRole() == 'admin'
      ) && isDoctorActive(resource.data.doctorId);
    }
    
    // Contact form submissions
    match /contacts/{contactId} {
      allow create: if true;
      allow read: if isSignedIn() && getUserRole() == 'admin';
    }
  }
}
