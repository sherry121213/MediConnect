
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL CLINICAL ACCESS PROTOCOL (V4.0)
     * [DEPLOYMENT HEARTBEAT] 2024-05-27 10:20:00 UTC
     * 
     * Grants absolute read/write clearance for authenticated clinical workflows.
     * Explicitly permits "list" queries on the appointments collection.
     */
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Public inquiry access
    match /contacts/{id} {
      allow create: if true;
    }
  }
}
