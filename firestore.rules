
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - TOTAL ACCESS PROTOCOL
     * [RESOLVE] "Missing or insufficient permissions"
     * This rule grants absolute read and write clearance to all 
     * authenticated users for all collections and subcollections.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * [PUBLIC] Unauthenticated Access
     * Allows public inquiries and professional discovery.
     */
    match /contacts/{id} {
      allow create: if true;
    }
    
    match /doctors/{id} {
      allow read: if true;
    }

    match /patients/{id} {
      allow read: if true;
    }
  }
}
