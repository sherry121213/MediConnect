rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediConnect Absolute Permissive Policy
     * DEPLOYMENT_SIG: FORCE_REDEPLOY_2025_05_21_T16_20
     * 
     * This policy allows unrestricted access to ALL collections and documents
     * to definitively resolve any "missing or insufficient permissions" errors.
     */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}