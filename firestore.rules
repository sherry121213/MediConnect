
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MEDICONNECT - UNIVERSAL ACCESS PROTOCOL (V6.0)
     * [DEPLOYMENT HEARTBEAT] 2024-06-02 09:15:00 UTC
     * 
     * Grants absolute read/write clearance for all clinical collections.
     * This explicitly resolves permission errors for appointments, history, and queue tracking.
     */
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Public inquiry fallback
    match /contacts/{id} {
      allow create: if true;
    }
  }
}
