
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * FINAL_ACTIVE_SESSION_PROTOCOL_V1
     * Providing absolute permissive access to all clinical data paths.
     */
    match /{document=**} {
      allow read, write: if true;
    }
    match /appointments/{doc=**} { allow read, write: if true; }
    match /patients/{doc=**} { allow read, write: if true; }
    match /doctors/{doc=**} { allow read, write: if true; }
    match /consultationLogs/{doc=**} { allow read, write: if true; }
  }
}
