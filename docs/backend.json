
{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Represents a user (patient, doctor, or admin) on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "profileComplete": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Detailed professional profile for healthcare providers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "medicalSchool": { "type": "string" },
        "degree": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "verified": { "type": "boolean" },
        "isActive": { "type": "boolean" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Clinical consultation record with queue management.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "appointmentDateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled", "expired"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "queueStatus": { "type": "string", "enum": ["waiting", "in-consultation", "late", "shifted", "completed"] },
        "sequencePosition": { "type": "number" },
        "blockId": { "type": "string" }
      }
    },
    "SupportSession": {
      "title": "SupportSession",
      "description": "A chat session between a user and admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/patients/{userId}": {
      "schema": { "$ref": "#/backend/entities/Patient" },
      "description": "Master user records."
    },
    "/doctors/{doctorId}": {
      "schema": { "$ref": "#/backend/entities/Doctor" },
      "description": "Professional doctor profiles."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/backend/entities/Appointment" },
      "description": "Clinical booking and queue records."
    },
    "/supportChatSessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/SupportSession" },
      "description": "Patient support channels."
    },
    "/adminDoctorChatSessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/SupportSession" },
      "description": "Provider administrative channels."
    },
    "/consultationSessions/{sessionId}": {
      "schema": "object",
      "description": "Real-time consultation chat transcripts."
    },
    "/missedSessionAudits/{auditId}": {
      "schema": "object",
      "description": "Archive of untended clinical slots."
    },
    "/contacts/{contactId}": {
      "schema": "object",
      "description": "Public inquiries."
    },
    "/doctorUnavailabilityRequests/{requestId}": {
      "schema": "object",
      "description": "Leave and pause requests."
    }
  }
}
