{
  "entities": {
    "Patient": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Patient",
      "type": "object",
      "description": "Represents a user (patient or doctor) on the Mediconnect platform. This document serves as the primary identity record.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user, matching their Auth UID."
        },
        "firstName": {
          "type": "string",
          "description": "User's first name."
        },
        "lastName": {
          "type": "string",
          "description": "User's last name."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user on the platform.",
          "enum": ["patient", "doctor", "admin"]
        },
        "phone": {
          "type": "string",
          "description": "User's phone number."
        },
        "dateOfBirth": {
          "type": "string",
          "description": "User's date of birth.",
          "format": "date"
        },
        "address": {
          "type": "string",
          "description": "User's address."
        },
        "photoURL": {
          "type": "string",
          "description": "URL of the user's profile picture.",
          "format": "uri"
        },
        "profileComplete": {
          "type": "boolean",
          "description": "Indicates if the user has completed their profile setup."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the user record was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of when the user record was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "email",
        "role"
      ]
    },
    "Doctor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Doctor",
      "type": "object",
      "description": "Represents a doctor's professional profile on the Mediconnect platform. Linked to a Patient document via UID.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the doctor, matching their Auth UID."
        },
        "firstName": {
          "type": "string",
          "description": "Doctor's first name."
        },
        "lastName": {
          "type": "string",
          "description": "Doctor's last name."
        },
        "email": {
          "type": "string",
          "description": "Doctor's email address.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Doctor's phone number."
        },
        "specialty": {
          "type": "string",
          "description": "Doctor's medical specialty."
        },
        "experience": {
          "type": "number",
          "description": "Doctor's years of professional experience."
        },
        "medicalSchool": {
          "type": "string",
          "description": "Medical school attended."
        },
        "degree": {
          "type": "string",
          "description": "Degrees earned."
        },
        "documents": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "description": "List of URLs to uploaded professional documents/degrees."
        },
        "location": {
          "type": "string",
          "description": "Doctor's practice location."
        },
        "rating": {
          "type": "number",
          "description": "Doctor's average rating."
        },
        "reviews": {
          "type": "number",
          "description": "Total number of reviews."
        },
        "verified": {
          "type": "boolean",
          "description": "Indicates if the doctor's profile has been verified by an admin."
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the doctor's account is active and visible."
        },
        "profileComplete": {
          "type": "boolean",
          "description": "Indicates if the professional profile is complete."
        },
        "photoURL": {
          "type": "string",
          "description": "URL of the doctor's profile picture.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the doctor record was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of when the doctor record was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "email",
        "specialty"
      ]
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents an appointment booked between a patient and a doctor.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the appointment."
        },
        "patientId": {
          "type": "string",
          "description": "Reference to Patient (user UID)."
        },
        "doctorId": {
          "type": "string",
          "description": "Reference to Doctor (user UID)."
        },
        "appointmentDateTime": {
          "type": "string",
          "description": "Date and time of the appointment.",
          "format": "date-time"
        },
        "appointmentType": {
          "type": "string",
          "description": "Type of appointment (e.g., Video Call, Audio, Chat)."
        },
        "status": {
          "type": "string",
          "description": "Status of the appointment (scheduled, completed, cancelled).",
          "enum": ["scheduled", "completed", "cancelled"]
        },
        "diagnosis": {
          "type": "string",
          "description": "The diagnosis provided by the doctor."
        },
        "prescription": {
          "type": "string",
          "description": "The prescription details provided by the doctor."
        },
        "amount": {
          "type": "number",
          "description": "The consultation fee."
        },
        "paymentReceiptUrl": {
          "type": "string",
          "description": "URL or Data URI of the payment receipt.",
          "format": "uri"
        },
        "paymentStatus": {
          "type": "string",
          "description": "Status of the payment.",
          "enum": ["pending", "approved", "rejected"]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of creation.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of last update.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "patientId",
        "doctorId",
        "appointmentDateTime",
        "status"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ],
    "customClaims": ["admin", "doctorId"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/patients/{patientId}",
        "definition": {
          "entityName": "Patient",
          "schema": {
            "$ref": "#/backend/entities/Patient"
          },
          "description": "User profiles for identity and core info."
        }
      },
      {
        "path": "/doctors/{doctorId}",
        "definition": {
          "entityName": "Doctor",
          "schema": {
            "$ref": "#/backend/entities/Doctor"
          },
          "description": "Professional details for doctors."
        }
      },
      {
        "path": "/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": {
            "$ref": "#/backend/entities/Appointment"
          },
          "description": "Appointment records."
        }
      }
    ],
    "reasoning": "Simple, role-based structure allowing authenticated access."
  }
}