{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Represents a user (patient, doctor, or admin) on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "profileComplete": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Detailed professional profile for healthcare providers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "location": { "type": "string" },
        "verified": { "type": "boolean" },
        "profileComplete": { "type": "boolean" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Clinical consultation record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "appointmentDateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      }
    },
    "ConsultationChatMessage": {
      "title": "ConsultationChatMessage",
      "description": "A message sent during a live session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/patients/{userId}": {
      "schema": { "$ref": "#/backend/entities/Patient" },
      "description": "Master user records and role-based access data."
    },
    "/doctors/{doctorId}": {
      "schema": { "$ref": "#/backend/entities/Doctor" },
      "description": "Detailed professional credentials for doctors."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/backend/entities/Appointment" },
      "description": "Clinical booking and payment records."
    },
    "/consultationSessions/{sessionId}/messages/{messageId}": {
      "schema": { "$ref": "#/backend/entities/ConsultationChatMessage" },
      "description": "Real-time clinical chat logs."
    },
    "/doctorUnavailabilityRequests/{requestId}": {
      "schema": "object",
      "description": "Clinical absence and leave audit requests."
    },
    "/adminDoctorChatSessions/{chatId}": {
      "schema": "object",
      "description": "Administrative support channels for providers."
    }
  }
}