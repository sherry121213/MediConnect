
{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Represents a user (patient, doctor, or admin) on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "profileComplete": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "photoURL": { "type": "string", "description": "Cloud Storage URL for profile identification." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Detailed professional profile for healthcare providers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "medicalSchool": { "type": "string" },
        "degree": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "verified": { "type": "boolean" },
        "profileComplete": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "DoctorCredential": {
      "title": "DoctorCredential",
      "description": "A specific professional document (degree, cert) linked to a doctor.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "doctorId": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Clinical consultation record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "appointmentDateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled", "expired"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "paymentReceiptUrl": { "type": "string" },
        "diagnosis": { "type": "string" },
        "prescription": { "type": "string" },
        "doctorInRoom": { "type": "boolean" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Patient feedback and rating for a doctor.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "appointmentId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "appointmentId", "rating"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Information from the contact us form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/patients/{userId}": {
      "schema": { "$ref": "#/backend/entities/Patient" },
      "description": "Master user records."
    },
    "/doctors/{doctorId}": {
      "schema": { "$ref": "#/backend/entities/Doctor" },
      "description": "Professional doctor profiles."
    },
    "/doctorCredentials/{credentialId}": {
      "schema": { "$ref": "#/backend/entities/DoctorCredential" },
      "description": "Independently stored professional degrees and certs."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/backend/entities/Appointment" },
      "description": "Clinical booking records."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/backend/entities/Review" },
      "description": "Public patient feedback records."
    },
    "/contacts/{contactId}": {
      "schema": { "$ref": "#/backend/entities/Contact" },
      "description": "Inquiry records."
    }
  }
}
