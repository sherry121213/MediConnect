
{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Represents a user (patient, doctor, or admin) on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "profileComplete": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Detailed professional profile for healthcare providers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "location": { "type": "string" },
        "verified": { "type": "boolean" },
        "profileComplete": { "type": "boolean" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Clinical consultation record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "appointmentDateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled", "expired"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      }
    },
    "MissedSessionAudit": {
      "title": "MissedSessionAudit",
      "description": "Log of sessions missed by doctors for admin review.",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientId": { "type": "string" },
        "scheduledTime": { "type": "string", "format": "date-time" },
        "loggedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/patients/{userId}": {
      "schema": { "$ref": "#/backend/entities/Patient" },
      "description": "Master user records and role-based access data."
    },
    "/doctors/{doctorId}": {
      "schema": { "$ref": "#/backend/entities/Doctor" },
      "description": "Detailed professional credentials for doctors."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/backend/entities/Appointment" },
      "description": "Clinical booking and payment records."
    },
    "/missedSessionAudits/{auditId}": {
      "schema": { "$ref": "#/backend/entities/MissedSessionAudit" },
      "description": "Logs of expired sessions for administrative follow-up."
    }
  }
}
