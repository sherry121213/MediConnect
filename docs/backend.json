
{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Represents a user (patient, doctor, or admin) on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "profileComplete": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "phone": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date-time" },
        "address": { "type": "string" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Professional healthcare provider record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "medicalSchool": { "type": "string" },
        "degree": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "verified": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "profileImageId": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "profileComplete": { "type": "boolean" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Clinical consultation record with queue management metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "appointmentDateTime": { "type": "string", "format": "date-time" },
        "appointmentType": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled", "expired"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "paymentMethod": { "type": "string" },
        "amount": { "type": "number" },
        "diagnosis": { "type": "string" },
        "prescription": { "type": "string" },
        "blockId": { "type": "string" },
        "sequencePosition": { "type": "number" },
        "queueStatus": { "type": "string", "enum": ["waiting", "in-consultation", "late", "shifted", "completed"] },
        "readyToStart": { "type": "boolean" },
        "patientCheckedIn": { "type": "boolean" },
        "doctorInRoom": { "type": "boolean" },
        "isExtended": { "type": "boolean" },
        "paymentReceiptUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SupportSession": {
      "title": "SupportSession",
      "description": "Administrative chat session metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "doctorId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "lastMessageContent": { "type": "string" },
        "lastMessageSenderRole": { "type": "string" },
        "unreadByAdmin": { "type": "boolean" },
        "status": { "type": "string" }
      }
    },
    "Contact": {
      "title": "Contact",
      "description": "Public inquiry record.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/patients/{userId}": {
      "schema": { "$ref": "#/backend/entities/Patient" },
      "description": "Master clinical user identity records."
    },
    "/doctors/{doctorId}": {
      "schema": { "$ref": "#/backend/entities/Doctor" },
      "description": "Verified professional provider profiles."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/backend/entities/Appointment" },
      "description": "Precision clinical booking and queue management data."
    },
    "/contacts/{contactId}": {
      "schema": { "$ref": "#/backend/entities/Contact" },
      "description": "Global public inquiries."
    },
    "/reviews/{reviewId}": {
      "schema": "object",
      "description": "Patient feedback and clinical standards audits."
    },
    "/doctorCredentials/{credentialId}": {
      "schema": "object",
      "description": "High-fidelity medical evidence archive (PDFs/Images)."
    },
    "/supportChatSessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/SupportSession" },
      "description": "Patient administrative support channels."
    },
    "/adminDoctorChatSessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/SupportSession" },
      "description": "Provider-Admin high-stakes clinical support lines."
    },
    "/consultationSessions/{sessionId}/messages/{messageId}": {
      "schema": "object",
      "description": "Real-time encrypted consultation transcripts."
    },
    "/missedSessionAudits/{auditId}": {
      "schema": "object",
      "description": "Regulatory archive for untended clinical slots."
    },
    "/doctorUnavailabilityRequests/{requestId}": {
      "schema": "object",
      "description": "Provider pause and clinical leave audits."
    },
    "/calls/{callId}": {
      "schema": "object",
      "description": "WebRTC signaling metadata for precision sessions."
    }
  }
}
