{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Represents a user (patient, doctor, or admin) on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "profileComplete": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "photoURL": { "type": "string", "description": "Cloud Storage URL for profile identification." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Detailed professional profile for healthcare providers including clinical credentials.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "medicalSchool": { "type": "string" },
        "degree": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "documents": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Array of Storage Bucket URLs referencing clinical degrees and certificates."
        },
        "verified": { "type": "boolean" },
        "profileComplete": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Clinical consultation record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "appointmentDateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled", "expired"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "paymentReceiptUrl": { "type": "string", "description": "Storage URL for payment verification evidence." },
        "diagnosis": { "type": "string" },
        "prescription": { "type": "string" },
        "doctorInRoom": { "type": "boolean" }
      }
    },
    "SupportChatSession": {
      "title": "SupportChatSession",
      "description": "A communication channel between a user and admin support.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "unreadByAdmin": { "type": "boolean" },
        "status": { "type": "string", "enum": ["open", "closed"] }
      }
    },
    "ConsultationLog": {
      "title": "ConsultationLog",
      "description": "System log of when a clinical session is started and finished.",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientId": { "type": "string" },
        "action": { "type": "string", "enum": ["started", "ended"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/patients/{userId}": {
      "schema": { "$ref": "#/backend/entities/Patient" },
      "description": "Master user records and role-based access data."
    },
    "/doctors/{doctorId}": {
      "schema": { "$ref": "#/backend/entities/Doctor" },
      "description": "Detailed professional credentials for doctors."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/backend/entities/Appointment" },
      "description": "Clinical booking and payment records."
    },
    "/supportChatSessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/SupportChatSession" },
      "description": "High-level support session metadata."
    }
  }
}